  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "clear && cross-env NODE_ENV=development nest start",
    "start:dev": "clear && cross-env NODE_ENV=development nest start --watch",
    "start:debug": "clear && cross-env NODE_ENV=development nest start --debug --watch",
    "start:prod": "clear && cross-env NODE_ENV=production node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "clear && npx prisma migrate reset -f --skip-generate --skip-seed && jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "clear && jest --config ./jest-e2e.config.ts  --detectOpenHandles --forceExit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.529.1",
